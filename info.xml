<?xml version="1.0"?>
<extension key="msgtplsender" type="module">
  <file>msgtplsender</file>
  <name>Message Template Sender</name>
  <description>Adds customised forms for sending emails using message templates</description>
  <license>AGPL-3.0</license>
  <authors>
    <author>
      <name>MJW</name>
      <email>info@mjwconsult.co.uk</email>
      <role>Maintainer</role>
    </author>
  </authors>
  <urls>
    <url desc="Main Extension Page">https://github.com/mjwconsult/civicrm-msgtplsender</url>
    <url desc="Release Notes">https://github.com/mjwconsult/civicrm-msgtplsender/blob/master/docs/releasenotes.md</url>
    <url desc="Support">https://mjw.pt/support/msgtplsender</url>
    <url desc="Licensing">http://www.gnu.org/licenses/agpl-3.0.html</url>
  </urls>
  <releaseDate>2026-06-27</releaseDate>
  <version>1.4.0</version>
  <develStage>stable</develStage>
  <compatibility>
    <ver>6.14</ver>
  </compatibility>
  <classloader>
    <psr0 prefix="CRM_" path="."/>
    <psr4 prefix="Civi\" path="Civi"/>
  </classloader>
  <civix>
    <namespace>CRM/Msgtplsender</namespace>
    <format>25.10.2</format>
  </civix>
  <mixins>
    <mixin>menu-xml@1.0.0</mixin>
    <mixin>smarty@1.0.3</mixin>
  </mixins>
</extension>
